<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CONTENT CREW • Join Us</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    body { font-family: 'Inter', system-ui, sans-serif; }
    .neon-text { text-shadow: 0 0 20px rgb(168 85 247); }
  </style>
</head>
<body class="bg-zinc-950 text-white">

  <!-- NAVBAR -->
  <nav class="border-b border-white/10 bg-zinc-950/80 backdrop-blur-lg fixed w-full z-50">
    <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-gradient-to-br from-purple-500 to-cyan-400 rounded-xl flex items-center justify-center text-xl">🔥</div>
        <h1 class="text-2xl font-bold tracking-tighter">CONTENT CREW</h1>
      </div>
      <div class="flex gap-8 text-sm font-medium">
        <a href="#staff" class="hover:text-purple-400 transition">Staff Application</a>
        <a href="#content" class="hover:text-purple-400 transition">Content Creator</a>
        <a href="#faq" class="hover:text-purple-400 transition">FAQ</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex items-center pt-20 bg-gradient-to-b from-zinc-950 via-purple-950/30 to-zinc-950">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-6xl md:text-7xl font-bold tracking-tighter neon-text mb-4">
        JOIN THE CREW
      </h2>
      <p class="text-2xl text-zinc-400 max-w-2xl mx-auto mb-10">
        Staff or Content Creator applications are now open.<br>
        Fast • Simple • Real opportunities
      </p>
      <div class="flex justify-center gap-4">
        <a href="#staff" class="px-8 py-4 bg-white text-black font-semibold rounded-2xl flex items-center gap-2 hover:scale-105 transition">
          <i class="fa-solid fa-briefcase"></i> Staff Application
        </a>
        <a href="#content" class="px-8 py-4 border border-white/30 font-semibold rounded-2xl flex items-center gap-2 hover:bg-white/10 transition">
          <i class="fa-solid fa-video"></i> Content Creator Application
        </a>
      </div>
    </div>
  </section>

  <!-- APPLICATION TABS -->
  <div class="max-w-4xl mx-auto px-6 -mt-12 relative z-10">
    <div class="bg-zinc-900 rounded-3xl shadow-2xl border border-white/10 p-2 flex gap-2 mb-8">
      <button onclick="switchTab(0)" id="tab-0"
        class="tab-btn flex-1 py-4 text-lg font-semibold rounded-2xl data-[active=true]:bg-purple-600 data-[active=true]:shadow-inner transition">
        Staff Application
      </button>
      <button onclick="switchTab(1)" id="tab-1"
        class="tab-btn flex-1 py-4 text-lg font-semibold rounded-2xl data-[active=true]:bg-purple-600 data-[active=true]:shadow-inner transition">
        Content Creator Application
      </button>
    </div>

    <!-- STAFF FORM -->
    <div id="form-0" class="form-panel">
      <form action="https://formsubmit.co/YOUR_EMAIL_HERE@gmail.com" method="POST" class="space-y-6">
        <input type="hidden" name="application_type" value="STAFF">
        <input type="hidden" name="_subject" value="NEW STAFF APPLICATION!">
        <input type="hidden" name="_captcha" value="false">

        <div class="grid grid-cols-2 gap-6">
          <div>
            <label class="block text-sm mb-2 font-medium">Full Name</label>
            <input type="text" name="name" required class="w-full bg-zinc-800 border border-white/10 rounded-2xl px-5 py-4 focus:border-purple-500 outline-none">
          </div>
          <div>
            <label class="block text-sm mb-2 font-medium">Discord Username</label>
            <input type="text" name="discord" placeholder="username#0000" required class="w-full bg-zinc-800 border border-white/10 rounded-2xl px-5 py-4 focus:border-purple-500 outline-none">
          </div>
        </div>

        <div>
          <label class="block text-sm mb-2 font-medium">Email</label>
          <input type="email" name="email" required class="w-full bg-zinc-800 border border-white/10 rounded-2xl px-5 py-4 focus:border-purple-500 outline-none">
        </div>

        <div>
          <label class="block text-sm mb-2 font-medium">Position Applying For</label>
          <select name="position" required class="w-full bg-zinc-800 border border-white/10 rounded-2xl px-5 py-4 focus:border-purple-500 outline-none">
            <option value="">Select position...</option>
            <option value="Moderator">Moderator</option>
            <option value="Editor / Video Editor">Editor / Video Editor</option>
            <option value="Manager">Manager</option>
            <option value="Thumbnail Designer">Thumbnail Designer</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div>
          <label class="block text-sm mb-2 font-medium">Previous Experience (be detailed)</label>
          <textarea name="experience" rows="4" required class="w-full bg-zinc-800 border border-white/10 rounded-3xl px-5 py-4 focus:border-purple-500 outline-none"></textarea>
        </div>

        <div>
          <label class="block text-sm mb-2 font-medium">Why do you want to join the Crew?</label>
          <textarea name="why" rows="4" required class="w-full bg-zinc-800 border border-white/10 rounded-3xl px-5 py-4 focus:border-purple-500 outline-none"></textarea>
        </div>

        <button type="submit" id="submit-staff"
          class="w-full py-6 bg-gradient-to-r from-purple-600 to-cyan-500 text-xl font-bold rounded-3xl hover:brightness-110 transition">
          SUBMIT STAFF APPLICATION
        </button>
      </form>
    </div>

    <!-- CONTENT CREATOR FORM -->
    <div id="form-1" class="form-panel hidden">
      <form action="https://formsubmit.co/YOUR_EMAIL_HERE@gmail.com" method="POST" class="space-y-6">
        <input type="hidden" name="application_type" value="CONTENT CREATOR">
        <input type="hidden" name="_subject" value="NEW CONTENT CREATOR APPLICATION!">
        <input type="hidden" name="_captcha" value="false">

        <div class="grid grid-cols-2 gap-6">
          <div>
            <label class="block text-sm mb-2 font-medium">Full Name</label>
            <input type="text" name="name" required class="w-full bg-zinc-800 border border-white/10 rounded-2xl px-5 py-4 focus:border-purple-500 outline-none">
          </div>
          <div>
            <label class="block text-sm mb-2 font-medium">TikTok Username</label>
            <input type="text" name="tiktok" placeholder="@yourusername" required class="w-full bg-zinc-800 border border-white/10 rounded-2xl px-5 py-4 focus:border-purple-500 outline-none">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-6">
          <div>
            <label class="block text-sm mb-2 font-medium">Followers</label>
            <input type="text" name="followers" placeholder="12.4K" class="w-full bg-zinc-800 border border-white/10 rounded-2xl px-5 py-4 focus:border-purple-500 outline-none">
          </div>
          <div>
            <label class="block text-sm mb-2 font-medium">Average Views per Video</label>
            <input type="text" name="avg_views" placeholder="150K - 500K" required class="w-full bg-zinc-800 border border-white/10 rounded-2xl px-5 py-4 focus:border-purple-500 outline-none">
          </div>
        </div>

        <div>
          <label class="block text-sm mb-2 font-medium">Link to your TikTok profile or best video</label>
          <input type="url" name="tiktok_link" placeholder="https://tiktok.com/..." required class="w-full bg-zinc-800 border border-white/10 rounded-2xl px-5 py-4 focus:border-purple-500 outline-none">
        </div>

        <div>
          <label class="block text-sm mb-2 font-medium">What kind of content do you make?</label>
          <input type="text" name="niche" placeholder="Gaming, Dance, Comedy, Lifestyle..." required class="w-full bg-zinc-800 border border-white/10 rounded-2xl px-5 py-4 focus:border-purple-500 outline-none">
        </div>

        <div>
          <label class="block text-sm mb-2 font-medium">Why do you want to join the CONTENT CREW?</label>
          <textarea name="why" rows="4" required class="w-full bg-zinc-800 border border-white/10 rounded-3xl px-5 py-4 focus:border-purple-500 outline-none"></textarea>
        </div>

        <button type="submit" id="submit-content"
          class="w-full py-6 bg-gradient-to-r from-purple-600 to-cyan-500 text-xl font-bold rounded-3xl hover:brightness-110 transition">
          SUBMIT CONTENT APPLICATION
        </button>
      </form>
    </div>
  </div>

  <!-- SUCCESS MODAL -->
  <div id="success-modal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-[100]">
    <div class="bg-zinc-900 rounded-3xl p-10 max-w-md text-center">
      <i class="fa-solid fa-check-circle text-6xl text-green-500 mb-6"></i>
      <h3 class="text-3xl font-bold mb-3">Application Received!</h3>
      <p class="text-zinc-400 mb-8">Thank you! We will review it and get back to you within 48 hours.</p>
      <button onclick="hideModal()" class="px-10 py-4 bg-white text-black font-bold rounded-2xl">CLOSE</button>
    </div>
  </div>

  <!-- FAQ -->
  <section id="faq" class="max-w-4xl mx-auto px-6 py-24">
    <h2 class="text-4xl font-bold text-center mb-12">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div class="bg-zinc-900 rounded-3xl p-8">
        <p class="font-semibold text-purple-400">How long until I hear back?</p>
        <p class="text-zinc-400 mt-2">Usually within 48 hours. We review every application personally.</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8">
        <p class="font-semibold text-purple-400">Do I need a big following to join?</p>
        <p class="text-zinc-400 mt-2">No. We care more about consistency, vibe, and attitude than follower count.</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8">
        <p class="font-semibold text-purple-400">Is this paid?</p>
        <p class="text-zinc-400 mt-2">Staff positions are paid. Content creators get paid per video + bonuses.</p>
      </div>
    </div>
  </section>

  <footer class="text-center py-12 text-zinc-500 text-sm border-t border-white/10">
    © CONTENT CREW • All applications go straight to our team inbox
  </footer>

  <script>
    // Tailwind init
    function initializeTailwind() {
      return {
        config(userConfig = {}) {
          return {
            content: [],
            theme: {
              extend: {},
            },
            plugins: [],
            ...userConfig,
          }
        },
        theme: {
          extend: {},
        },
      }
    }
    document.addEventListener("DOMContentLoaded", () => {
      const config = initializeTailwind().config()
      return config
    })

    // Tab switching
    function switchTab(n) {
      document.querySelectorAll('.form-panel').forEach(panel => panel.classList.add('hidden'))
      document.getElementById('form-' + n).classList.remove('hidden')

      document.querySelectorAll('.tab-btn').forEach(btn => btn.dataset.active = 'false')
      document.getElementById('tab-' + n).dataset.active = 'true'
    }

    // Success modal
    function showModal() {
      document.getElementById('success-modal').classList.remove('hidden')
      document.getElementById('success-modal').classList.add('flex')
    }
    function hideModal() {
      const modal = document.getElementById('success-modal')
      modal.classList.add('hidden')
      modal.classList.remove('flex')
    }

    // Handle form submissions
    document.querySelectorAll('form').forEach(form => {
      form.addEventListener('submit', function(e) {
        const btn = this.querySelector('button[type="submit"]')
        const originalText = btn.innerHTML
        
        btn.innerHTML = `
          <span class="flex items-center justify-center gap-2">
            <i class="fa-solid fa-spinner fa-spin"></i>
            SENDING...
          </span>
        `
        // formsubmit.co will redirect, but we show success first
        setTimeout(() => {
          showModal()
          btn.innerHTML = originalText
        }, 800)
      })
    })

    // Make first tab active by default
    window.onload = () => switchTab(0)
  </script>
</body>
</html>
